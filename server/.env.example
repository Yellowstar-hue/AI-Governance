# AISafe Server Configuration
# For Railway: set these as environment variables in the Railway dashboard
# Railway auto-provides DATABASE_URL and REDIS_URL when you add those services

# Server
PORT=3000
NODE_ENV=production

# Database (Railway provides DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# OR use individual vars for local dev:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aisafe
DB_USER=aisafe_user
DB_PASSWORD=your_password_here

# Redis (Railway provides REDIS_URL automatically)
# REDIS_URL=redis://default:pass@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (REQUIRED - set a strong random secret)
JWT_SECRET=change-this-to-a-very-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# CORS (set to your frontend Railway URL)
CORS_ORIGIN=https://your-client.up.railway.app

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email (optional - for sending notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=app-password
# EMAIL_FROM=noreply@aisafe.in

# Logging
LOG_LEVEL=info
